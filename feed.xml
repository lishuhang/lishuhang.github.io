---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ site.lang | default: 'zh-CN' }}">
  <title>{{ site.title | escape }}</title>
  <subtitle>{{ site.description | escape }}</subtitle>
  <link href="{{ site.url }}/" rel="alternate" type="text/html"/>
  <link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml"/>
  <id>{{ site.url }}/</id>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.author.name | escape }}</name>
    <email>{{ site.author.email }}</email>
  </author>
  {% for post in site.posts limit:20 %}
  <entry>
    <title>{{ post.title | escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html"/>
    <id>{{ post.url | absolute_url }}</id>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.updated | default: post.date | date_to_xmlschema }}</updated>
    <content type="html" xml:base="{{ post.url | absolute_url }}">{{ post.content | escape }}</content>
    {% if post.summary %}
    <summary>{{ post.summary | escape }}</summary>
    {% else %}
    <summary>{{ post.excerpt | strip_html | truncatewords: 50 | escape }}</summary>
    {% endif %}
    {% for tag in post.tags %}
    <category term="{{ tag | escape }}"/>
    {% endfor %}
  </entry>
  {% endfor %}
</feed>
